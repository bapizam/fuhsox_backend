# Force npm to install devDependencies during the build even when
# NODE_ENV=production (Render sets this by default). The build pipeline
# needs devDependencies at build time: ts-node + tsconfig-paths for the
# prisma seed, and typescript + tsc-alias + all @types/* for `npm run build`.
# `include=dev` overrides the implicit `omit=dev` from NODE_ENV=production.
include=dev
