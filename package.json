{
  "name": "fuhsox-api",
  "version": "1.0.0",
  "description": "FuhsoX â€” Intelligent Exam Preparation & Academic Engagement Platform Backend",
  "author": "Revision Software Foundation",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child -r tsconfig-paths/register src/index.ts",
    "build": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/src/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "jest --runInBand --detectOpenHandles",
    "test:unit": "jest --config jest.unit.config.js --runInBand",
    "test:integration": "jest --testPathPattern='tests/integration' --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "db:studio": "prisma studio",
    "workers:start": "ts-node -r tsconfig-paths/register src/jobs/workers/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-ses": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.18.0",
    "@sentry/node": "^8.20.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^17.4.2",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "google-auth-library": "^9.13.0",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mjml": "^4.15.3",
    "mongoose": "^8.6.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "pdf-parse": "^1.1.1",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "prisma": "^5.18.0",
    "rate-limit-redis": "^4.2.0",
    "sanitize-html": "^2.13.0",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
