# ─── FuhsoX API — production .env for the single-VM Docker stack ───────────────
# Copy to `.env` ON THE SERVER (never commit the filled-in file) and set every
# value. docker-compose.prod.yml reads this for BOTH container secrets and for
# ${...} interpolation (the datastore passwords + DOMAIN).
#
# NOTE: DATABASE_URL / MONGODB_URI / REDIS_URL are NOT set here — the compose
# file derives them from the passwords below + the internal service names, so
# there is nothing to keep in sync.

# ─── Public hostname (Caddy issues HTTPS for this) ────────────────────────────
# The domain that points at this VM's public IP. A free DuckDNS subdomain works,
# e.g. fuhsox.duckdns.org. Must resolve to the box BEFORE `up`, or cert issuance
# fails. The mobile app will use https://<DOMAIN>/api/v1.
DOMAIN=your-subdomain.duckdns.org

# ─── Datastore passwords (any long random strings; used only inside the VM) ───
POSTGRES_PASSWORD=change-me-long-random
MONGO_PASSWORD=change-me-long-random
REDIS_PASSWORD=change-me-long-random

# ─── App server ───────────────────────────────────────────────────────────────
# CORS / Socket.io origin. No web client yet — set it to the API's own URL so it
# is a valid URL (env validation requires one); the mobile app is unaffected.
FRONTEND_URL=https://your-subdomain.duckdns.org

# ─── JWT (generate each with: openssl rand -hex 32) ───────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-web-client-secret
GOOGLE_REDIRECT_URI=https://your-subdomain.duckdns.org/api/v1/auth/google
# Native mobile client (required for native Google sign-in on the app).
GOOGLE_ANDROID_CLIENT_ID=132562342401-dmh2uhh97h8r239sa46vesar5bn9nhvm.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=

# ─── Apple Sign-In (optional; leave blank until you have an Apple account) ─────
APPLE_CLIENT_ID=org.revisionsoftware.fuhsox

# ─── AI (required to BOOT — must start with sk-ant-) ──────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=sk-ant-your-key
AI_DAILY_QUESTION_LIMIT=20

# ─── AWS (required to BOOT) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=af-south-1
AWS_S3_BUCKET=your-bucket-name
AWS_SES_FROM_EMAIL=verified-sender@yourdomain.com

# ─── Object storage: avatars + PDFs (optional) ────────────────────────────────
# Storage speaks plain S3, so any S3-compatible provider works. Unset = use the
# AWS_* values above. Set these to run storage off AWS WITHOUT re-crediting SES,
# which shares AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
#
# Supabase Storage is the free option (1 GB, no card) — see .env.example for the
# step-by-step. STORAGE_PUBLIC_BASE_URL is required whenever STORAGE_ENDPOINT is
# set; the service refuses to boot without it.
STORAGE_ENDPOINT=
STORAGE_PUBLIC_BASE_URL=
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# ─── Sentry (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Email ────────────────────────────────────────────────────────────────────
# Render blocks outbound SMTP ports (25/465/587) on free web services, so
# MAIL_PROVIDER=smtp will TIME OUT here no matter the provider. Both supported
# options below are HTTPS:443 APIs and work fine on the free tier.
#
# 'ses' — production. Two gotchas that fail silently at send time (service boots):
#   1. AWS_SES_FROM_EMAIL must be a verified identity in AWS_REGION — SES is
#      per-region. (Object storage no longer has to share that region: set
#      STORAGE_REGION above to decouple them.)
#   2. A sandbox SES account only delivers to VERIFIED recipients. Request
#      production access or OTPs vanish for everyone else.
MAIL_PROVIDER=ses

# 'brevo' — free tier, good for testing this deployment before SES is out of
# sandbox. Swap MAIL_PROVIDER above to 'brevo' and set these two:
# BREVO_API_KEY=            # the REST API key, NOT the SMTP key
# MAIL_FROM_EMAIL=          # must be a sender verified in the Brevo dashboard
