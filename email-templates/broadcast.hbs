<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Message from {{institution_name}}</title>
  <style>
    * { box-sizing: border-box; }
    body { margin:0; padding:20px 0; background:#f0f4f8; font-family:'Segoe UI', Arial, sans-serif; color:#1f2937; }
    .container { max-width:600px; margin:0 auto; background:#ffffff; border-radius:14px; overflow:hidden; box-shadow:0 4px 24px rgba(0,0,0,0.08); }
    .header { background:#0f2d5e; padding:28px 40px; display:flex; align-items:center; gap:16px; }
    .header-text h1 { color:#ffffff; font-size:18px; font-weight:700; margin:0; }
    .header-text p  { color:rgba(255,255,255,0.65); font-size:12px; margin:3px 0 0; }
    .greeting { padding:32px 40px 8px; font-size:15px; color:#374151; }
    .content { padding:8px 40px 32px; font-size:15px; color:#374151; line-height:1.7; }
    /* Allow admin-supplied HTML to render naturally within this container */
    .content h1, .content h2, .content h3 { color:#0f2d5e; margin:20px 0 10px; }
    .content p  { margin:0 0 14px; }
    .content a  { color:#1a56db; }
    .content ul, .content ol { padding-left:20px; margin:0 0 14px; }
    .content li { margin-bottom:6px; }
    .content blockquote { border-left:4px solid #1a56db; margin:16px 0; padding:12px 20px; background:#f0f4ff; color:#374151; border-radius:0 6px 6px 0; }
    .content img { max-width:100%; border-radius:8px; }
    .content table { width:100%; border-collapse:collapse; margin-bottom:14px; }
    .content table th { background:#0f2d5e; color:#fff; padding:8px 12px; text-align:left; font-size:13px; }
    .content table td { padding:8px 12px; border-bottom:1px solid #e5e7eb; font-size:13px; }
    .footer { background:#f4f6f9; padding:20px 40px; border-top:1px solid #e5e7eb; text-align:center; font-size:12px; color:#9ca3af; }
    .footer a { color:#6b7280; text-decoration:none; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="header-text">
        <h1>{{institution_name}}</h1>
        <p>Official Communication &mdash; Powered by FuhsoX</p>
      </div>
    </div>

    <div class="greeting">
      <p>Dear {{user_name}},</p>
    </div>

    <div class="content">
      {{{html_body}}}
    </div>

    <div class="footer">
      <p>
        &copy; {{year}} {{institution_name}}. All rights reserved.<br/>
        This is an official communication from your institution via FuhsoX.<br/>
        <a href="#">Manage email preferences</a>
      </p>
    </div>
  </div>
</body>
</html>
