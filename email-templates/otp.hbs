<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <meta name="x-apple-disable-message-reformatting"/>
  <meta name="color-scheme" content="dark"/>
  <meta name="supported-color-schemes" content="dark"/>
  <title>Your verification code</title>
  <!--[if mso]>
  <noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>
  <![endif]-->
  <!--[if !mso]><!-->
  <style type="text/css">@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');</style>
  <!--<![endif]-->
  <style type="text/css">
    :root { color-scheme:dark; supported-color-schemes:dark; }
    body,table,td,a { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }
    table,td { mso-table-lspace:0pt; mso-table-rspace:0pt; }
    body { margin:0 !important; padding:0 !important; width:100% !important; }
    a { text-decoration:none; }
    @media only screen and (max-width:620px) {
      .card { width:100% !important; }
      .wrap { padding:20px 12px !important; }
      .px   { padding-left:24px !important; padding-right:24px !important; }
      .h1   { font-size:21px !important; line-height:29px !important; }
      .code { font-size:30px !important; letter-spacing:8px !important; text-indent:8px !important; }
    }
  </style>
</head>
<body style="margin:0; padding:0; width:100%; background-color:#060910;">

  <div style="display:none; font-size:1px; color:#060910; line-height:1px; max-height:0; max-width:0; opacity:0; overflow:hidden;">
    Your {{institution_name}} sign-in code is valid for {{expiry_minutes}} minutes.
    &#847;&zwnj;&nbsp;&#847;&zwnj;&nbsp;&#847;&zwnj;&nbsp;&#847;&zwnj;&nbsp;&#847;&zwnj;&nbsp;&#847;&zwnj;&nbsp;&#847;&zwnj;&nbsp;&#847;&zwnj;&nbsp;
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" bgcolor="#060910" style="background-color:#060910;">
    <tr>
      <td class="wrap" align="center" style="padding:40px 16px; background-color:#060910; background-image:linear-gradient(180deg,#0A0E1A 0%,#0D1424 42%,#060910 100%);">

        <table role="presentation" class="card" width="600" cellpadding="0" cellspacing="0" border="0" style="width:600px; max-width:600px; background-color:#0D1424; border-radius:22px; overflow:hidden;">

          <!-- Neon spectrum rule -->
          <tr>
            <td height="3" style="height:3px; line-height:3px; font-size:0; background-color:#00E5FF; background-image:linear-gradient(90deg,#00E5FF 0%,#C57CFF 55%,#FF3DDB 100%);">&nbsp;</td>
          </tr>

          <!-- Header -->
          <tr>
            <td class="px" style="padding:34px 40px 26px; background-color:#0A0E1A; border-bottom:1px solid #232B3F;">
              <div style="font-family:'Manrope','Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif; font-size:26px; font-weight:800; letter-spacing:-0.5px; color:#FFFFFF; mso-line-height-rule:exactly; line-height:32px;">Fuhso<span style="color:#00E5FF; text-shadow:0 0 18px rgba(0,229,255,0.7);">X</span></div>
              <div style="margin-top:10px; font-family:'Manrope','Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif; font-size:11px; font-weight:600; letter-spacing:1.6px; text-transform:uppercase; color:#9A9FAC;">{{institution_name}}</div>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td class="px" style="padding:38px 40px 0;">
              <h1 class="h1" style="margin:0 0 14px; font-family:'Manrope','Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif; font-size:25px; line-height:33px; font-weight:800; letter-spacing:-0.4px; color:#FFFFFF;">Verify your sign-in</h1>
              <p style="margin:0 0 26px; font-family:'Manrope','Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif; font-size:15px; line-height:26px; color:#C7CCD8;">Enter the code below to finish signing in to your account. It stays valid for <strong style="color:#FFFFFF; font-weight:700;">{{expiry_minutes}} minutes</strong>.</p>
            </td>
          </tr>

          <!-- Code panel -->
          <tr>
            <td class="px" style="padding:0 40px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#141A2B; border:1px solid #2F3950; border-radius:16px;">
                <tr>
                  <td align="center" style="padding:30px 20px 26px;">
                    <div class="code" style="font-family:'Manrope','Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif; font-size:38px; line-height:46px; font-weight:800; letter-spacing:11px; text-indent:11px; color:#00E5FF; text-shadow:0 0 26px rgba(0,229,255,0.5); mso-line-height-rule:exactly;">{{otp_code}}</div>
                    <div style="margin-top:14px; font-family:'Manrope','Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif; font-size:11px; font-weight:600; letter-spacing:1.6px; text-transform:uppercase; color:#9A9FAC;">One-time verification code</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Expiry strip -->
          <tr>
            <td class="px" style="padding:22px 40px 0;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#2A2929; border-radius:10px;">
                <tr>
                  <td width="3" style="width:3px; font-size:0; line-height:0; background-color:#FFC24B;">&nbsp;</td>
                  <td style="padding:14px 18px; font-family:'Manrope','Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif; font-size:13px; line-height:21px; color:#C7CCD8;">
                    This code expires in <strong style="color:#FFC24B; font-weight:700;">{{expiry_minutes}} minutes</strong>. Request a new one if it runs out.
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Security note -->
          <tr>
            <td class="px" style="padding:26px 40px 36px;">
              <div style="border-top:1px solid #232B3F; padding-top:22px;">
                <div style="font-family:'Manrope','Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif; font-size:11px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; color:#00E5FF;">Security</div>
                <p style="margin:10px 0 0; font-family:'Manrope','Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif; font-size:13px; line-height:22px; color:#9A9FAC;">FuhsoX will never ask for this code by phone, chat or email. Enter it only on the official FuhsoX sign-in screen. If you didn't request it, you can safely ignore this message — your account stays secure.</p>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td class="px" align="center" style="padding:26px 40px 32px; background-color:#0A0E1A; border-top:1px solid #232B3F;">
              <p style="margin:0 0 6px; font-family:'Manrope','Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif; font-size:12px; line-height:20px; color:#9A9FAC;">&copy; {{year}} {{institution_name}} &middot; Powered by FuhsoX</p>
              <p style="margin:0; font-family:'Manrope','Segoe UI',-apple-system,BlinkMacSystemFont,Helvetica,Arial,sans-serif; font-size:11px; line-height:18px; letter-spacing:0.4px; color:#8A90A0;">Product of Revision Software Foundation</p>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>
