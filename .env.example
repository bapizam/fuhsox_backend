# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fuhsox:fuhsox_dev_pass@localhost:5432/fuhsox

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://fuhsox:fuhsox_dev_pass@localhost:27017/fuhsox?authSource=admin

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:fuhsox_redis_pass@localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=2eji4r90u59yi960i64ik9ikhi9j9rk90iky45i09k
JWT_REFRESH_SECRET=rij39u494tij94u5ythji46jiyj6u9iht0gkhrom
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Web client — the authorization-code exchange used by the web app.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Native clients (mobile). Google mints the id_token with the *native* client as
# its audience, so POST /auth/google verifies against [web, iOS, Android].
# Optional — leave unset to keep native Google sign-in disabled.
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# ─── Apple Sign-In (mobile) ───────────────────────────────────────────────────
# The app's bundle identifier — the audience of Apple's identity token.
# Optional: unset boots fine, but POST /auth/apple then returns a clear error.
APPLE_CLIENT_ID=org.revisionsoftware.fuhsox

# ─── Anthropic AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
AI_DAILY_QUESTION_LIMIT=50

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=af-south-1
AWS_S3_BUCKET=fuhsox-uploads
AWS_SES_FROM_EMAIL=noreply@fuhsox.ng


# ─── Email ────────────────────────────────────────────────────────────────────
# Transport for sendEmail(). Unset = SES in production, SMTP everywhere else.
# 'smtp' does NOT work on a free Render instance (Render blocks ports 25/465/587)
# — deployed environments must use 'ses'.
MAIL_PROVIDER=smtp

# Envelope From. Must be verified with whichever provider is active; falls back
# to AWS_SES_FROM_EMAIL when unset.
MAIL_FROM_EMAIL=noreply@fuhsox.ng

# --- Option A: MailHog (docker-compose, no account, UI on http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
# MailHog accepts no auth — leave these EMPTY for it, or the transport sends
# credentials it will reject.
SMTP_USER=
SMTP_PASS=

# --- Option B: Brevo over SMTP (free tier, delivers to real inboxes)
# LOCAL ONLY — port 587 is blocked on Render's free tier. Use Option C to deploy.
# MAIL_PROVIDER=smtp
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=<your-brevo-login>          # the SMTP login Brevo shows you
# SMTP_PASS=<your-brevo-smtp-key>       # the SMTP key — NOT your account password

# --- Option C: Brevo over HTTP (works locally AND on Render's free tier)
# MAIL_PROVIDER=brevo
# BREVO_API_KEY=<your-brevo-api-key>    # the REST API key — NOT the SMTP key
# MAIL_FROM_EMAIL must be a sender verified in the Brevo dashboard.
#
# NEVER commit real credentials to this file — it is tracked in git.

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@o000.ingest.sentry.io/0000000